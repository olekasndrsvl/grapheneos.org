#!/usr/bin/env python3

import os
from datetime import datetime, timezone
from os.path import getmtime

base = "https://grapheneos.org"

LANGUAGES = {
    'en': '',
    'de': '/de',
    'fr': '/fr',
    'es': '/es',
    'ru': '/ru',
}

pages = [
    ["/", 0.5],
    ["/.well-known/security.txt", 0.0],
    ["/LICENSE.txt", 0.0],
    ["/articles/", 0.5],
    ["/articles/attestation-compatibility-guide", 0.5],
    ["/articles/grapheneos-servers", 0.1],
    ["/articles/positon-location-service", 0.5],
    ["/articles/server-traffic-shaping", 0.5],
    ["/articles/sitewide-advertising-industry-opt-out", 0.5],
    ["/build", 0.5],
    ["/camera-privacy-policy", 0.0],
    ["/contact", 0.5],
    ["/donate", 0.5],
    ["/faq", 1.0],
    ["/features", 1.0],
    ["/history/", 0.3],
    ["/history/copperheados", 0.1],
    ["/history/legacy-changelog", 0.1],
    ["/hiring", 0.2],
    ["/humans.txt", 0.0],
    ["/pdfviewer-privacy-policy", 0.0],
    ["/install/", 0.5],
    ["/install/cli", 0.5],
    ["/install/web", 0.5],
    ["/releases", 0.5],
    ["/source", 0.5],
    ["/usage", 1.0]
]

def get_filepath(path, lang):
    lang_prefix = LANGUAGES[lang]
    static_dir = "static-tmp" if os.path.exists("static-tmp") else "static"
    full_path = f"{static_dir}{lang_prefix}{path}"
    if path.endswith('/'):
        full_path += "index.html"
    elif "." not in path:
        full_path += ".html"
    return full_path

def format_lastmod(timestamp):
    dt = datetime.fromtimestamp(timestamp, timezone.utc)
    return dt.strftime("%Y-%m-%dT%H:%M:%S+00:00")

static_dir = "static-tmp" if os.path.exists("static-tmp") else "static"
base_mtime = getmtime(static_dir)
entries = []

for page in pages:
    path = page[0]
    priority = page[1]
    
    entry_urls = []
    lastmod = None
    
    for lang, lang_prefix in LANGUAGES.items():
        loc = f"{base}{lang_prefix}{path}"
        
        filepath = get_filepath(path, lang)
        
        try:
            mtime = getmtime(filepath)
            if mtime > base_mtime:
                print(loc)
            lastmod = format_lastmod(mtime)
        except FileNotFoundError:
            pass
        
        entry_urls.append(f'<xhtml:link rel="alternate" hreflang="{lang}" href="{loc}"/>')
    
    entry_urls.append(f'<xhtml:link rel="alternate" hreflang="x-default" href="{base}{path}"/>')
    
    if lastmod is None:
        lastmod = format_lastmod(base_mtime)
    
    loc_en = base + path
    entries.append(f"""
    <url>
        <loc>{loc_en}</loc>
        <lastmod>{lastmod}</lastmod>
        <priority>{priority}</priority>
        {"".join(entry_urls)}
    </url>""")

sitemap = f"""<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">{"".join(entries)}
</urlset>
"""

output_dir = "static-tmp" if os.path.exists("static-tmp") else "static"
with open(f"{output_dir}/sitemap.xml", "w") as f:
    f.write(sitemap)

print(f"Generated multilingual sitemap.xml with hreflang in {output_dir}/")

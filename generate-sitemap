#!/usr/bin/env python3

from datetime import datetime, timezone
from os.path import getmtime
from pathlib import Path

base = "https://grapheneos.org"

# Languages supported by the site
LANGUAGES = ['en', 'de', 'fr', 'es', 'ru']

# Define pages and their priorities
pages = [
    ["/", 0.5],
    ["/.well-known/security.txt", 0.0],
    ["/LICENSE.txt", 0.0],
    ["/articles/", 0.5],
    ["/articles/attestation-compatibility-guide", 0.5],
    ["/articles/grapheneos-servers", 0.1],
    ["/articles/positon-location-service", 0.5],
    ["/articles/server-traffic-shaping", 0.5],
    ["/articles/sitewide-advertising-industry-opt-out", 0.5],
    ["/build", 0.5],
    ["/camera-privacy-policy", 0.0],
    ["/contact", 0.5],
    ["/donate", 0.5],
    ["/faq", 1.0],
    ["/features", 1.0],
    ["/history/", 0.3],
    ["/history/copperheados", 0.1],
    ["/history/legacy-changelog", 0.1],
    ["/hiring", 0.2],
    ["/humans.txt", 0.0],
    ["/pdfviewer-privacy-policy", 0.0],
    ["/install/", 0.5],
    ["/install/cli", 0.5],
    ["/install/web", 0.5],
    ["/releases", 0.5],
    ["/source", 0.5],
    ["/usage", 1.0]
]


def get_language_files():
    """Return all localized HTML files grouped by route."""
    lang_files = {}
    for lang in LANGUAGES:
        lang_path = Path(f"static-production/{lang}")
        if lang_path.exists():
            for html_file in lang_path.rglob('*.html'):
                # Get the relative path without the language prefix
                rel_path = str(html_file.relative_to(lang_path))
                # Convert index.html into /
                if rel_path == 'index.html':
                    rel_path = ''
                elif rel_path.endswith('.html'):
                    rel_path = rel_path[:-5]
                # Ensure the path starts with a slash
                if not rel_path.startswith('/'):
                    rel_path = '/' + rel_path

                if rel_path not in lang_files:
                    lang_files[rel_path] = {}
                lang_files[rel_path][lang] = html_file
    return lang_files


def get_all_page_paths():
    """Return all existing page paths from localized directories."""
    paths = set()
    for lang in LANGUAGES:
        lang_path = Path(f"static-production/{lang}")
        if lang_path.exists():
            for html_file in lang_path.rglob('*.html'):
                rel_path = str(html_file.relative_to(lang_path))
                if rel_path == 'index.html':
                    paths.add('/')
                elif rel_path.endswith('.html'):
                    paths.add('/' + rel_path[:-5])
                else:
                    paths.add('/' + rel_path)
    return paths


def get_file_path_for_lang(page_path, lang):
    """Return the file path for a page in a specific language."""
    if page_path == '/':
        filename = 'index.html'
    else:
        filename = page_path.lstrip('/') + '.html'

    filepath = Path(f"static-production/{lang}/{filename}")
    if filepath.exists():
        return filepath
    return None


def get_lastmod_for_page(page_path, lang):
    """Return the last-modified timestamp for a page."""
    filepath = get_file_path_for_lang(page_path, lang)
    if filepath and filepath.exists():
        try:
            mtime = getmtime(filepath)
            return datetime.fromtimestamp(mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")
        except OSError:
            pass
    return None


def url_for_page(page_path, lang):
    """Return the URL for a page in the specified language."""
    if lang == 'en':
        return base + page_path
    # Special-case the root page
    if page_path == '/':
        return base + '/' + lang + '/'
    return base + '/' + lang + page_path


def generate_sitemap():
    """Generate the multilingual sitemap."""
    entries = []
    base_mtime = getmtime("static-production")

    # Collect all existing pages
    all_pages = get_all_page_paths()

    for page in pages:
        path = page[0]
        priority = page[1]

        # Check whether at least one localized version exists
        has_any_version = False
        url_entries = []

        for lang in LANGUAGES:
            filepath = get_file_path_for_lang(path, lang)
            if filepath and filepath.exists():
                has_any_version = True
                loc = url_for_page(path, lang)
                lastmod = get_lastmod_for_page(path, lang)

                # If lastmod cannot be determined, fall back to the directory timestamp
                if not lastmod:
                    try:
                        mtime = getmtime(filepath)
                        lastmod = datetime.fromtimestamp(mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")
                    except OSError:
                        lastmod = datetime.fromtimestamp(base_mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")

                url_entries.append({
                    'loc': loc,
                    'lastmod': lastmod,
                    'lang': lang,
                    'priority': priority
                })

        # Skip pages that do not exist
        if not has_any_version:
            continue

        # Build the XML entries for this page
        xml_parts = []
        for entry in url_entries:
            xml_parts.append(f"""
    <url>
        <loc>{entry['loc']}</loc>
        <lastmod>{entry['lastmod']}</lastmod>
        <priority>{entry['priority']}</priority>""")

            # Add xhtml:link entries for all localized versions
            xhtml_links = []
            for other_entry in url_entries:
                if other_entry['lang'] != entry['lang']:
                    xhtml_links.append(f'        <xhtml:link rel="alternate" hreflang="{other_entry["lang"]}" href="{other_entry["loc"]}"/>')

            if xhtml_links:
                xml_parts[-1] += '\n' + '\n'.join(xhtml_links)

            # Add the self-referential alternate link for the current page
            xml_parts[-1] += f'\n        <xhtml:link rel="alternate" hreflang="{entry["lang"]}" href="{entry["loc"]}"/>'
            xml_parts[-1] += '\n    </url>'

        entries.extend(xml_parts)

    # Also include pages that exist on disk but are not listed in pages
    existing_paths = get_all_page_paths()
    for path in existing_paths:
        # Skip pages that were already handled above
        if any(page[0] == path for page in pages):
            continue

        # Check whether this is a non-HTML page such as robots.txt or sitemap.xml
        if path.endswith('.xml') or path.endswith('.txt') or path.endswith('.atom'):
            # Handle it as a regular file
            filepath = get_file_path_for_lang(path, 'en')
            if filepath and filepath.exists():
                try:
                    mtime = getmtime(filepath)
                    lastmod = datetime.fromtimestamp(mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")
                    entries.append(f"""
    <url>
        <loc>{base + path}</loc>
        <lastmod>{lastmod}</lastmod>
        <priority>0.0</priority>
    </url>""")
                except OSError:
                    pass
            continue

        # Handle HTML pages
        has_any_version = False
        url_entries = []

        for lang in LANGUAGES:
            filepath = get_file_path_for_lang(path, lang)
            if filepath and filepath.exists():
                has_any_version = True
                loc = url_for_page(path, lang)
                lastmod = get_lastmod_for_page(path, lang)

                if not lastmod:
                    try:
                        mtime = getmtime(filepath)
                        lastmod = datetime.fromtimestamp(mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")
                    except OSError:
                        lastmod = datetime.fromtimestamp(base_mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")

                url_entries.append({
                    'loc': loc,
                    'lastmod': lastmod,
                    'lang': lang,
                    'priority': 0.5  # Default priority for pages not listed explicitly
                })

        if has_any_version:
            for entry in url_entries:
                xml_parts = [f"""
    <url>
        <loc>{entry['loc']}</loc>
        <lastmod>{entry['lastmod']}</lastmod>
        <priority>{entry['priority']}</priority>"""]

                # Add xhtml:link entries for all localized versions
                xhtml_links = []
                for other_entry in url_entries:
                    if other_entry['lang'] != entry['lang']:
                        xhtml_links.append(f'        <xhtml:link rel="alternate" hreflang="{other_entry["lang"]}" href="{other_entry["loc"]}"/>')

                if xhtml_links:
                    xml_parts[-1] += '\n' + '\n'.join(xhtml_links)

                xml_parts[-1] += f'\n        <xhtml:link rel="alternate" hreflang="{entry["lang"]}" href="{entry["loc"]}"/>'
                xml_parts[-1] += '\n    </url>'
                entries.append(xml_parts[0])

    # Build the final sitemap document
    sitemap = f"""<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">{"".join(entries)}
</urlset>
"""

    with open("static-tmp/sitemap.xml", "w", encoding='utf-8') as f:
        f.write(sitemap)

    print("Generated multilingual sitemap.xml with hreflang attributes")

    # Also generate language-specific sitemap indexes
    generate_sitemap_index()


def generate_sitemap_index():
    """Generate the sitemap index for language-specific sitemaps."""
    entries = []
    base_mtime = getmtime("static-production")
    lastmod = datetime.fromtimestamp(base_mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")

    for lang in LANGUAGES:
        sitemap_url = f"{base}/sitemap_{lang}.xml"
        entries.append(f"""
    <sitemap>
        <loc>{sitemap_url}</loc>
        <lastmod>{lastmod}</lastmod>
    </sitemap>""")

    # Only generate the main index if language-specific sitemaps exist
    if entries:
        sitemap_index = f"""<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">{"".join(entries)}
</sitemapindex>
"""
        with open("static-tmp/sitemap_index.xml", "w", encoding='utf-8') as f:
            f.write(sitemap_index)
        print("Generated sitemap_index.xml")


def generate_lang_sitemaps():
    """Generate a separate sitemap for each language."""
    base_mtime = getmtime("static-production")

    for lang in LANGUAGES:
        entries = []
        lang_path = Path(f"static-production/{lang}")

        if not lang_path.exists():
            continue

        # Collect all HTML files for this language
        for html_file in lang_path.rglob('*.html'):
            rel_path = str(html_file.relative_to(lang_path))
            if rel_path == 'index.html':
                page_path = '/'
            elif rel_path.endswith('.html'):
                page_path = '/' + rel_path[:-5]
            else:
                page_path = '/' + rel_path

            # Determine the priority
            priority = 0.5
            for page in pages:
                if page[0] == page_path:
                    priority = page[1]
                    break

            loc = url_for_page(page_path, lang)

            try:
                mtime = getmtime(html_file)
                lastmod = datetime.fromtimestamp(mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")
            except OSError:
                lastmod = datetime.fromtimestamp(base_mtime, timezone.utc).strftime("%Y-%m-%dT%H:%M:%S%:z")

            entries.append(f"""
    <url>
        <loc>{loc}</loc>
        <lastmod>{lastmod}</lastmod>
        <priority>{priority}</priority>
    </url>""")

        if entries:
            sitemap = f"""<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">{"".join(entries)}
</urlset>
"""
            with open(f"static-tmp/sitemap_{lang}.xml", "w", encoding='utf-8') as f:
                f.write(sitemap)
            print(f"  Generated sitemap_{lang}.xml")


if __name__ == "__main__":
    # Generate the main multilingual sitemap
    generate_sitemap()

    # Generate separate sitemaps for each language
    generate_lang_sitemaps()

#!/usr/bin/env python3

from jinja2 import FileSystemLoader, Environment
from pathlib import Path
import os
import sys
import argparse
import shutil
import re

from jinja2i18n import create_i18n_environment, get_supported_languages, LANGUAGES


# SEO tags template (simple version)
def generate_seo_tags_simple(current_page, lang):
    """Generate SEO tags for a page (hreflang only)."""
    base_url = "https://grapheneos.org"
    languages = ['en', 'de', 'fr', 'es', 'ru']
    
    page_path = current_page.lstrip('/')
    
    tags = []
    
    # hreflang tags only
    for lang_code in languages:
        if lang_code == 'en':
            hreflang_url = f"{base_url}/{page_path}" if page_path else base_url + "/"
        else:
            hreflang_url = f"{base_url}/{lang_code}/{page_path}" if page_path else f"{base_url}/{lang_code}/"
        
        tags.append(f'<link rel="alternate" hreflang="{lang_code}" href="{hreflang_url}"/>')
    
    # x-default
    x_default = f"{base_url}/{page_path}" if page_path else base_url + "/"
    tags.append(f'<link rel="alternate" hreflang="x-default" href="{x_default}"/>')
    
    return '\n'.join(tags)


def process_templates(input_dir, output_dir=None, lang='en'):
    ROOT_DIR = Path(input_dir)
    
    if output_dir:
        OUTPUT_DIR = Path(output_dir)
        OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
        
        source_dir = ROOT_DIR
        if OUTPUT_DIR.exists() and any(OUTPUT_DIR.iterdir()):
            pass
        else:
            if OUTPUT_DIR.exists():
                shutil.rmtree(OUTPUT_DIR)
            shutil.copytree(source_dir, OUTPUT_DIR)
        target_dir = OUTPUT_DIR
    else:
        target_dir = ROOT_DIR
    
    # Setup Jinja2
    TEMPLATE_PATH_LIST = [str(target_dir), "templates/"]
    
    loader = FileSystemLoader(searchpath=TEMPLATE_PATH_LIST)
    environment = Environment(loader=loader, autoescape=True)
    
    # Add i18n functions
    i18n_context = create_i18n_environment(lang)
    for name, value in i18n_context.items():
        environment.globals[name] = value
    
    # Process all HTML files with Jinja2
    file_path_list = list(target_dir.glob("**/*.html"))
    template_file_list = [os.fspath(p.relative_to(target_dir)) for p in file_path_list]
    
    processed = 0
    for template_file in template_file_list:
        try:
            current_page = template_file.replace('.html', '').strip('/')
            if current_page == 'index':
                current_page = '/'
            
            # Render Jinja2 template
            template = environment.get_template(template_file)
            content = template.render(current_page=current_page)
            
            # Add SEO tags after canonical
            seo_tags = generate_seo_tags_simple(current_page, lang)
            if 'rel="canonical"' in content:
                content = content.replace(
                    '<link rel="canonical"',
                    seo_tags + '\n<link rel="canonical"'
                )
            elif 'rel=canonical>' in content:
                content = content.replace(
                    'rel=canonical>',
                    'rel=canonical>' + seo_tags + '\n'
                )
            
            path = os.path.join(target_dir, template_file)
            with open(path, 'w', encoding='utf-8') as f:
                f.write(content)
            
            processed += 1
        except Exception as e:
            print(f"Error processing {template_file}: {e}")
    
    print(f"Processed {processed} templates for language: {lang} ({LANGUAGES.get(lang, lang)})")
    return processed


def main():
    parser = argparse.ArgumentParser(description='Process Jinja2 templates')
    parser.add_argument('input_dir', help='Input directory with templates')
    parser.add_argument('--lang', '-l', default='en', 
                       choices=get_supported_languages(),
                       help=f'Language code (default: en). Available: {", ".join(get_supported_languages())}')
    parser.add_argument('--output', '-o', default=None,
                       help='Output directory (if different from input)')
    
    args = parser.parse_args()
    
    process_templates(args.input_dir, args.output, args.lang)


if __name__ == '__main__':
    main()

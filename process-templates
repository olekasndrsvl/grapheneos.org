#!/usr/bin/env python3
"""
process-templates with i18n support
Creates separate output directories for each language.
"""

import sys
import gettext
import shutil
import re
import traceback
from pathlib import Path
from jinja2 import FileSystemLoader, Environment
from jinja2_i18n_extras import create_i18n_environment


def create_translator(lang='en'):
    """Create a translation function with an English fallback."""

    def fallback(text):
        return text

    try:
        translations = gettext.translation(
            'grapheneos',
            localedir='locale',
            languages=[lang],
            fallback=True
        )
        return translations.gettext
    except Exception:
        print(f"  Info: No translations for {lang}, using English fallback")
        return fallback


def local_url(path, lang):
    """Generate a URL prefixed with the current language."""
    if path == '/':
        return f'/{lang}/'
    if path.startswith('/'):
        return f'/{lang}{path}'
    return f'/{lang}/{path}'


def process_html_content(content, lang, env):
    """Post-process HTML content and rewrite links to localized equivalents."""
    # Find href attributes that are not anchors and do not start with http
    def replace_href(match):
        href = match.group(1)
        # Skip anchors, external links, mailto, and javascript URLs
        if (href.startswith('#') or
                href.startswith('http://') or
                href.startswith('https://') or
                href.startswith('mailto:') or
                href.startswith('javascript:') or
                href.startswith('/.well-known/') or
                href.startswith('data:')):
            return f'href="{href}"'

        # Skip links to files with extensions other than .html
        file_extensions = ['.png', '.jpg', '.jpeg', '.gif', '.svg', '.ico',
                           '.woff', '.woff2', '.ttf', '.eot', '.css', '.js',
                           '.json', '.xml', '.txt', '.atom', '.zip', '.sig']
        if any(href.endswith(ext) for ext in file_extensions):
            return f'href="{href}"'

        # Rewrite relative paths
        if href.startswith('/'):
            new_href = local_url(href, lang)
        else:
            new_href = local_url('/' + href, lang)

        return f'href="{new_href}"'

    # Rewrite href attributes
    content = re.sub(r'href="([^"]+)"', replace_href, content)

    # Rewrite src attributes for images and scripts
    def replace_src(match):
        src = match.group(1)
        if src.startswith('/') and not src.startswith('//'):
            new_src = local_url(src, lang)
            return f'src="{new_src}"'
        return f'src="{src}"'

    content = re.sub(r'src="([^"]+)"', replace_src, content)

    return content


if len(sys.argv) != 2:
    print(f"Usage: {sys.argv[0]} <path>")
    sys.exit(1)

ROOT_DIR = Path(sys.argv[1])

# Create the Jinja environment
env = Environment(
    loader=FileSystemLoader([str(ROOT_DIR), 'templates']),
    autoescape=True
)

# Supported languages
LANGUAGES = ['en', 'de', 'fr', 'es', 'ru']

# Statistics
total_files = 0
translated_files = 0
error_files = []

# First create per-language directories and copy non-HTML assets into them
print("=== Copying static assets ===")
for lang in LANGUAGES:
    lang_dir = ROOT_DIR / lang
    lang_dir.mkdir(exist_ok=True)
    print(f"  Created directory: {lang_dir}")

    # Copy everything except HTML files and existing language directories
    for item in ROOT_DIR.iterdir():
        # Skip language directories
        if item.name in LANGUAGES:
            continue
        # Skip HTML files, they are handled separately
        if item.is_file() and item.suffix == '.html':
            continue

        dest = lang_dir / item.name
        if item.is_dir():
            if dest.exists():
                shutil.rmtree(dest)
            shutil.copytree(item, dest)
            print(f"    Copied directory: {item.name} -> {dest}")
        else:
            shutil.copy2(item, dest)
            print(f"    Copied file: {item.name} -> {dest}")

    print(f"✓ Copied assets for {lang}")

# Collect the list of HTML files before processing
print("\n=== Collecting HTML files ===")
html_files = []
for html_file in ROOT_DIR.rglob('*.html'):
    # Skip files inside language directories
    if any(part in LANGUAGES for part in html_file.parts):
        print(f"  Skipping (in lang dir): {html_file}")
        continue
    html_files.append(html_file)
    print(f"  Found: {html_file.relative_to(ROOT_DIR)}")

print(f"Found {len(html_files)} HTML files to process")

# Process HTML files for each language
print("\n=== Processing HTML templates ===")
for lang in LANGUAGES:
    lang_dir = ROOT_DIR / lang
    print(f"\n--- Processing {lang} ---")

    # Create the translation function for this language
    _ = create_translator(lang)
    env.globals['_'] = _
    env.globals['lang'] = lang
    env.globals['local_url'] = lambda path: local_url(path, lang)

    # Get i18n extensions for this language
    i18n_extras = create_i18n_environment(lang)

    # Add functions to globals
    for name, func in i18n_extras['functions'].items():
        env.globals[name] = func

    # Add filters
    for name, filter_func in i18n_extras['filters'].items():
        env.filters[name] = filter_func

    # Process each HTML file
    for html_file in html_files:
        total_files += 1

        # Get the relative path
        rel_path = html_file.relative_to(ROOT_DIR)

        # Build request_path for canonical URL generation
        page_path = str(rel_path)
        if page_path.endswith('.html'):
            page_path = page_path[:-5]  # Strip the .html suffix

        # index.html should map to /
        if page_path == 'index' or page_path == '':
            page_path = '/'
        else:
            page_path = '/' + page_path

        output_file = lang_dir / rel_path

        print(f"  Processing: {rel_path} -> {output_file}")

        # Create parent directories
        try:
            output_file.parent.mkdir(parents=True, exist_ok=True)
            print(f"    Created parent dirs: {output_file.parent}")
        except Exception as e:
            print(f"    ✗ Failed to create parent dirs: {e}")
            error_files.append((html_file, lang, e))
            continue

        try:
            # Load and render the template
            print(f"    Loading template: {rel_path}")
            template = env.get_template(str(rel_path))

            print("    Rendering template...")
            # Render with request_path added to the context
            rendered = template.render(
                _=_,
                lang=lang,
                local_url=lambda path: local_url(path, lang),
                request_path=page_path  # Provide the current page path
            )

            # Perform an extra pass over links not handled by Jinja2
            rendered = process_html_content(rendered, lang, env)

            print(f"    Writing to: {output_file}")
            with open(output_file, 'w', encoding='utf-8') as f:
                f.write(rendered)

            translated_files += 1
            print(f"    ✓ Success! File size: {len(rendered)} bytes")

            # Confirm that the output file was actually created
            if output_file.exists():
                print(f"    ✓ Confirmed file exists: {output_file}")
            else:
                print("    ✗ WARNING: File was not created!")

        except Exception as e:
            print(f"    ✗ ERROR: {e}")
            print("    Traceback:")
            traceback.print_exc()
            error_files.append((html_file, lang, e))

print("\n=== Summary ===")
print(f"Total files processed: {total_files}")
print(f"Successfully translated: {translated_files}")
print(f"Errors: {len(error_files)}")

if error_files:
    print("\n=== Errors ===")
    for html_file, lang, error in error_files[:10]:
        print(f"  {lang}/{html_file.relative_to(ROOT_DIR)}: {error}")
    if len(error_files) > 10:
        print(f"  ... and {len(error_files) - 10} more errors")

print("\n=== Output locations ===")
for lang in LANGUAGES:
    lang_dir = ROOT_DIR / lang
    html_count = len(list(lang_dir.rglob('*.html')))
    print(f"  {lang}: {html_count} HTML files in {lang_dir}")

print("\n=== IMPORTANT ===")
print("Original HTML files are PRESERVED in:", ROOT_DIR)
print("Translated versions are in:", [ROOT_DIR / lang for lang in LANGUAGES])
